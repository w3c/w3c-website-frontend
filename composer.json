{
    "name": "w3c/website-frontend",
    "description": "W3C website frontend application",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.2",
        "ext-ctype": "*",
        "ext-dom": "*",
        "ext-iconv": "*",
        "ext-json": "*",
        "chrisguitarguy/request-id-bundle": "^6.0",
        "composer/package-versions-deprecated": "^1.11",
        "ekreative/health-check-bundle": "^1.13.0",
        "friendsofsymfony/http-cache-bundle": "^3.4",
        "guzzlehttp/promises": "2.3",
        "nelmio/cors-bundle": "^2.6",
        "nyholm/psr7": "^1.8",
        "phpdocumentor/reflection-docblock": "^6.0",
        "sabre/vobject": "^4.5",
        "strata/symfony-frontend": "^0.9",
        "symfony/asset": "*",
        "symfony/console": "*",
        "symfony/dotenv": "*",
        "symfony/expression-language": "*",
        "symfony/flex": "^2.10",
        "symfony/form": "*",
        "symfony/framework-bundle": "*",
        "symfony/http-client": "*",
        "symfony/intl": "*",
        "symfony/mailer": "*",
        "symfony/mime": "*",
        "symfony/monolog-bundle": "^3.11",
        "symfony/notifier": "*",
        "symfony/process": "*",
        "symfony/property-access": "*",
        "symfony/property-info": "*",
        "symfony/proxy-manager-bridge": "^6.4",
        "symfony/security-bundle": "*",
        "symfony/security-csrf": "*",
        "symfony/serializer": "*",
        "symfony/string": "*",
        "symfony/translation": "*",
        "symfony/twig-bundle": "*",
        "symfony/validator": "*",
        "symfony/web-link": "*",
        "symfony/yaml": "*",
        "twig/extra-bundle": "^3.24",
        "twig/twig": "^3.24",
        "w3c/website-templates-bundle": "dev-main"
    },
    "require-dev": {
        "overtrue/phplint": "^9.7",
        "phpunit/phpunit": "^11.5",
        "rector/rector": "^2.3",
        "roave/security-advisories": "dev-latest",
        "squizlabs/php_codesniffer": "^4.0",
        "studio24/deployer-recipes": "^2.2",
        "symfony/browser-kit": "*",
        "symfony/css-selector": "*",
        "symfony/debug-bundle": "*",
        "symfony/maker-bundle": "^1.67",
        "symfony/panther": "^2.4",
        "symfony/phpunit-bridge": "^8.0",
        "symfony/stopwatch": "*",
        "symfony/var-dumper": "*",
        "symfony/web-profiler-bundle": "*"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "symfony/flex": true,
            "php-http/discovery": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*"
    },
    "scripts": {
        "auto-scripts": {
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "cache:clear": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "test": [
            "./vendor/bin/phplint",
            "./vendor/bin/phpcs",
            "php ./bin/console lint:container",
            "./vendor/bin/phpunit"
        ]
    },
    "scripts-descriptions": {
        "test": "Run all required tests"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.4.*"
        }
    }
}
